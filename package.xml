<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<package format="1" xmlns="https://wiki.freecad.org/Package_Metadata">

  <name>GenCAD</name>
  <description>GenCAD is a FreeCAD workbench for creating, modifying, and exporting FreeCAD objects to code using natural language.</description>
  <version>0.2.0</version>
  <date>2026-05-01</date>
  <maintainer email="it.project.devel@gmail.com">Vasily S</maintainer>
  <license file="LICENSE">LGPL-2.1-or-later</license>
  <url type="repository" branch="main">https://github.com/drfenixion/freecad.gencad</url>
  <url type="readme">https://github.com/drfenixion/freecad.gencad/blob/main/README.md</url>
  <icon>gencad_icon.svg</icon>

  <freecadmin>1.0</freecadmin>

  <content>
    <workbench>
      <pythonmin>3.11</pythonmin>
      <!-- tags -->
      <tag>AI</tag>
      <tag>generative</tag>
      <tag>text to object</tag>
      <tag>modify by text</tag>
      <tag>object to code</tag>      
    </workbench>
  </content>

</package>
